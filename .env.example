# Site URL - Required for OG images and absolute URLs in metadata
# Format: https://yourdomain.com (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://example.com

# Optional: GitHub Pages base path (leave empty for root deployment)
# Only needed for GitHub Pages subdirectory deployment
# Examples:
#   - /portfolio
#   - /my-portfolio
#   - (leave empty for Vercel/Netlify/root deployment)
NEXT_PUBLIC_BASE_PATH=
